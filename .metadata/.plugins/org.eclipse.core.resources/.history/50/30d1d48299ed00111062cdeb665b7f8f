	class MyPanel extends JPanel{
		
		private Ball ball;
		
		public MyPanel(Ball ball){
			this.ball = ball;
		}
		@Override
		public void paintComponent(Graphics g) {
			
			
			Graphics2D g2 = (Graphics2D)g;
			g2.clearRect(0, 0, 500, 500);
			//g2.setColor(new Color(255,0,0));
			/*g2.drawImage(Toolkit.getDefaultToolkit().createImage("images\\f016.gif"), new AffineTransform() , 
					this);*/
			/*g2.drawImage(Toolkit.getDefaultToolkit().createImage("e:\\a.jpg"),
                    100,
                    100,
                    this);*/
			g2.setColor(Color.red);
			Calendar c = new GregorianCalendar();
			int second = c.get(Calendar.SECOND);
			int dw = 80;
			double du = second * 1.0 / 60 * Math.PI * 2;
			du = Math.PI/2 - du;
			g2.drawLine(200,200,(int)(200 + dw * Math.cos(du)),(int)(200 - dw * Math.sin(du)));
			
			//g2.drawString("dafdsafdsa", 100, 100);
			
		}
	}
	
	class Ball {
		private int x;
		private int y;
		private int dx = 5;
		private int dy = 8;
		private int dwidth =20;
		private Dimension dim;
		public Ball(Dimension d){
			dim = d;
		}
		
		public int getX(){
			return x;
		}
		public int getY(){
			return y;
		}
		public int getRa(){
			return dwidth;
		}
		
		public void move(){
			x += dx;
			y += dy;
			
			if (x + dwidth > dim.getWidth() - 100) {
				dx = -dx;
			}
			if (x < 0) {
				dx = -dx;
			}
			if (y + dwidth > dim.getHeight() - 100) {
				dy = -dy;
			}
			if (y < 0) {
				dy = -dy;
			}
		}
		
		
	}
