	class Rece extends Thread {
		public void run(){
			while (isRun) {
				try {
					Object value = ois.readObject();
				
					 if ( value  instanceof Message) {
						 Message mess = (Message)value;
						 if (mess.getIp() == null)  {
							 String allmess = "";
							 allmess += "sender:" + mess.getSendName() + "\n";
							 allmess += "to :" + mess.getToName() + "\n";
							 allmess += mess.getMessage();
							 textArea.append(allmess);
						 } else {
							 ReceFile rf = new ReceFile(mess);
							 rf.start();
						 }
					 } else {
						 User user = (User)value;
						 if (user.getType() == 9) {
							 users.removeElement(user);
						 } else {
							 if (!users.contains(value)) {
								 users.addElement(value);
						 
							 }
						 }
							 
					 }
				} catch (IOException e) {
					// TODO Auto-generated catch block
					e.printStackTrace();
				} catch (ClassNotFoundException e) {
					// TODO Auto-generated catch block
					e.printStackTrace();
				}
			}
		}
	}
	
	class SendFile extends Thread{
		private int port;
		private File file;
		public SendFile(int port,File file){
			this.port = port;
			this.file = file;
		}
		public void run(){
			
			try {
				ServerSocket server = new ServerSocket(port);
				Socket socket = server.accept();
				InputStream is = socket.getInputStream();
				OutputStream os = socket.getOutputStream();
				FileInputStream fis = new FileInputStream(file);
				int c = is.read();
				if (c == 'a') {
					byte[] buffer = new byte[102400];
					int len = fis.read(buffer);
					while (len != -1) {
						os.write(buffer, 0, len);
						os.flush();
						len = fis.read(buffer);
					}
					os.close();
					is.close();
					socket.close();
					server.close();
					JOptionPane.showMessageDialog(ChatFrame.this, "ОДјю·ўЛННк±П");
				} else {
					JOptionPane.showMessageDialog(ChatFrame.this, "¶Ф·ЅѕЬѕшЅУКЬОДјю");
				}
				
			} catch (IOException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		}
	}
	
	class ReceFile extends Thread{
		
		private Message mess;
		public ReceFile(Message mess) {
			
			this.mess = mess;
		}
		public void run(){
			Socket socket = null;
			try {
				socket = new Socket(mess.getIp(),mess.getCode());
			} catch (UnknownHostException e1) {
				// TODO Auto-generated catch block
				e1.printStackTrace();
			} catch (IOException e1) {
				// TODO Auto-generated catch block
				e1.printStackTrace();
			}
			try {
				InputStream is = socket.getInputStream();
				OutputStream os = socket.getOutputStream();
				int type = JOptionPane.showConfirmDialog(ChatFrame.this, mess.getMessage());
				if (type == JOptionPane.YES_OPTION) {
					os.write('a');
					os.flush();
					byte[] buffer = new byte[102400];
					int len = is.read(buffer);
					JFileChooser jfc = new JFileChooser(".");
					File file  = new File(mess.getMessage().substring(mess.getMessage().indexOf('(') + 1, mess.getMessage().indexOf(')')));
					jfc.setSelectedFile(file);
					jfc.showSaveDialog(ChatFrame.this);
					file = new File(jfc.getSelectedFile().getAbsolutePath());
					FileOutputStream fos = new FileOutputStream(file);
					while (len != -1) {
						fos.write(buffer, 0, len);
						fos.flush();
						len = is.read(buffer);
					}
					
					fos.close();
					os.close();
					is.close();
					socket.close();
					JOptionPane.showMessageDialog(ChatFrame.this, "ОДјюЅУКЬНк±П");
				} else {
					os.write('b');
					os.flush();
				}
			} catch (IOException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
			
		}
	}
