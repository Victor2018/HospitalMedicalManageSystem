package com.goudan.ui;

import java.awt.BorderLayout;
import java.awt.Color;
import java.awt.Dimension;
import java.awt.Graphics;
import java.awt.Graphics2D;

import javax.swing.JFrame;
import javax.swing.JPanel;

public class PaintTest extends JFrame {

	/**
	 * @param args
	 */
	public static void main(String[] args) {
		// TODO Auto-generated method stub
		PaintTest pt = new PaintTest();
		
		pt.setVisible(true);
		pt.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
	}
	public PaintTest() {
		super();
		setBounds(100, 100, 500, 500);
		final MyPanel panel = new MyPanel(this.getSize());
		
		
		getContentPane().add(panel, BorderLayout.CENTER);
		panel.repaint();
	}
	
	
	class MyPanel extends JPanel{
		private Dimension d ;
		public MyPanel(Dimension d){
			this.d = d;
		}
		@Override
		public void paint(Graphics g) {
			System.out.println("paintComp");
			Graphics2D g2 = (Graphics2D)g;
			g2.setColor(new Color(255,0,0));
			g2.fillOval(0, 0, 20, 20);
			System.out.println(d.getHeight() + ":" + d.getWidth());
		}
	}
}


