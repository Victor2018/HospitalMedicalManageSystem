	class MyCellRenderer extends JLabel implements ListCellRenderer {
	     final  ImageIcon longIcon = new ImageIcon("e:\\f011.gif");
	     final  ImageIcon shortIcon = new ImageIcon("e:\\f007.gif");

	     // This is the only method defined by ListCellRenderer.
	     // We just reconfigure the JLabel each time we're called.

	     public Component getListCellRendererComponent(
	       JList list,              // the list
	       Object value,            // value to display
	       int index,               // cell index
	       boolean isSelected,      // is the cell selected
	       boolean cellHasFocus)    // does the cell have focus
	     {
	         String s = value.toString();
	         System.out.println("cell:" +_ s);
	         
	         setText(s);
	         setIcon((s.length() > 10) ? longIcon : shortIcon);
	         if (isSelected) {
	             setBackground(list.getSelectionBackground());
	             setForeground(list.getSelectionForeground());
	         } else {
	             setBackground(list.getBackground());
	             setForeground(list.getForeground());
	         }
	         setEnabled(list.isEnabled());
	         setFont(list.getFont());
	         setOpaque(true);
	         return this;
	     }
	 }


	class MyModel  extends AbstractListModel{//implements ListModel{
		
		private List datas = new ArrayList();
		public void addElement(Object data){
			
			int index = datas.size();
			datas.add(data);
			fireIntervalAdded(this, index, index);
		}
		public MyModel(){
			
		}
		public MyModel(List datas){
			this.datas = datas;
		}
		

		public Object getElementAt(int index) {
			// TODO Auto-generated method stub
			return datas.get(index);
		}

		public int getSize() {
			// TODO Auto-generated method stub
			return datas.size();
		}
		  public boolean removeElement(Object obj) {
				int index = datas.indexOf(obj);
				boolean rv = datas.remove(obj);
				if (index >= 0) {
				    fireIntervalRemoved(this, index, index);
				}
				return rv;
		}

		
		
	}


